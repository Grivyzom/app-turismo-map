# =========================================================================
# CONFIGURACIÓN DEL ENTORNO - APP TURISMO MAP
# Copia este archivo como ".env" antes de iniciar docker-compose o impórtalo
# en Portainer como variables de entorno del Stack.
# =========================================================================

# -------------------------------------------------------------------------
# 1. BASE DE DATOS POSTGRESQL (CON SOPORTE POSTGIS)
# -------------------------------------------------------------------------
# Nota: "db" es el nombre del servicio en docker-compose, resolverá internamente.
DB_HOST=db
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=cambiar_por_una_contrasena_segura_1234
DB_NAME=app-turismo
DB_SSLMODE=disable

# -------------------------------------------------------------------------
# 2. REDIS CACHE
# -------------------------------------------------------------------------
# Nota: "redis" es el nombre del servicio en docker-compose, resolverá internamente.
REDIS_ADDR=redis:6379

# -------------------------------------------------------------------------
# 3. BACKEND (GO API)
# -------------------------------------------------------------------------
PORT=8080
GOOGLE_WEB_CLIENT_ID=257845944673-cboekti02t2043v3gqhgikv3m7m8h4k9.apps.googleusercontent.com
# IMPORTANTE: Genere una clave fuerte con: openssl rand -base64 64
# Mínimo 32 caracteres. El servidor NO arrancará sin esta variable.
JWT_SECRET=GENERAR_CON_openssl_rand_-base64_64

# -------------------------------------------------------------------------
# 4. FRONTEND (EXPO WEB / COMPILACIÓN)
# Estas variables se inyectan en el HTML/JS durante el proceso de build.
# -------------------------------------------------------------------------
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=AIzaSyDpkt-MwlCOYi3kpA9Jl6WHz8rYC5FPV-8
EXPO_PUBLIC_GOOGLE_MAPS_ANDROID_API_KEY=AIzaSyDN1rgcLJuLEpxKunJX1r2KFWxkBRtxe64
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=257845944673-cboekti02t2043v3gqhgikv3m7m8h4k9.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=257845944673-lg6t67ru4513feq32ns9f8mq82cksjb0.apps.googleusercontent.com

# URL pública del backend a la que se conectará el cliente desde su navegador.
# Reemplaza por la IP de tu dedicado o tu dominio (ej: http://api.tudominio.com:8080)
EXPO_PUBLIC_BACKEND_URL=http://localhost:8080
